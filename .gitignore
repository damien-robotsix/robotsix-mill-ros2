# Cloned workspace sources are managed via repos.yaml, never committed
/src/*
!/src/.gitkeep

# ROS2 / colcon build artifacts
/build/
/install/
/log/

# Python bytecode and caches
*.pyc
*.pyo
__pycache__/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Python coverage
.coverage
htmlcov/
colcon_*_coverage/
*.gcno
*.gcda
*.gcov
lcov/

# IDE and editor config
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Environment and tooling
.direnv/
.env
.venv/
venv/

# ROS2-specific markers
AMENT_IGNORE
CATKIN_IGNORE
